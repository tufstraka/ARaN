# Wallet private key for deployment (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# RPC URLs (use one of these or get your own from Alchemy/Infura)
# Public nodes (free but may be slow):
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Or use Alchemy (recommended - free tier available):
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# API Keys for contract verification (optional)
ETHERSCAN_API_KEY=your_etherscan_api_key
BASESCAN_API_KEY=your_basescan_api_key
